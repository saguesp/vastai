download_all_hf_models() {
  if [ "${#HF_MODELS[@]}" -eq 0 ]; then return 0; fi
  mkdir -p "$HF_STAGING_DIR"

  if [ -n "$HF_TOKEN" ]; then
    hf auth login --token "$HF_TOKEN" --add-to-git-credential false >/dev/null 2>&1 ||       log "AVISO: hf auth login no pudo validar/escribir credenciales; se seguirá pasando --token en cada descarga."
  fi

  log "Descargando ${#HF_MODELS[@]} archivos pesados con paralelismo activo (Máx: ${HF_MAX_PARALLEL})..."

  local pids=()
  local model repo file_path output_path

  for model in "${HF_MODELS[@]}"; do
    repo="${model%%|*}"
    file_path="${model#*|}"
    file_path="${file_path%%|*}"
    output_path="${model##*|}"
    download_hf_file "$repo" "$file_path" "$output_path" &
    pids+=("$!")
  done

  local failed=0
  for pid in "${pids[@]}"; do
    if ! wait "$pid"; then failed=1; fi
  done

  if [ "$failed" -ne 0 ]; then
    log "AVISO: una o más descargas de Hugging Face fallaron. Reporte: ${HF_FAILURE_REPORT}"
    if [ "$ALLOW_HF_DOWNLOAD_FAILURES" = "1" ]; then
      log "Continuando porque ALLOW_HF_DOWNLOAD_FAILURES=1. Cambia a 0 si quieres fallo estricto."
      return 0
    fi
    return 1
  fi
}

download_hf_file() {
  local repo="$1"
  local file_path="$2"
  local output_path="$3"
  local lockfile="${output_path}.lock"
  local slot
  local temp_dir
  local attempt
  local cmd_log
  local status

  slot=$(acquire_slot)
  mkdir -p "$(dirname "$output_path")"

  while ! mkdir "$lockfile" 2>/dev/null; do
    sleep 1
  done

  if [ -s "$output_path" ]; then
    rmdir "$lockfile" || true
    release_slot "$slot"
    return 0
  fi

  local hf_token_args=()
  if [ -n "$HF_TOKEN" ]; then hf_token_args=(--token "$HF_TOKEN"); fi

  attempt=1
  while [ "$attempt" -le "$HF_DOWNLOAD_RETRIES" ]; do
    temp_dir=$(mktemp -d "${HF_STAGING_DIR}/download.XXXXXX")
    cmd_log="${output_path}.download_attempt_${attempt}.log"

    if [ "$attempt" -eq 1 ]; then
      log "Descargando vía hf_transfer/xet: ${repo}/${file_path}"
      set +e
      HF_HUB_ENABLE_HF_TRANSFER="$HF_HUB_ENABLE_HF_TRANSFER" HF_XET_HIGH_PERFORMANCE="$HF_XET_HIGH_PERFORMANCE"         hf download "$repo" "$file_path" --repo-type model --local-dir "$temp_dir" "${hf_token_args[@]}" >"$cmd_log" 2>&1
      status=$?
      set -e
    else
      log "Reintentando descarga estándar sin hf_transfer/xet: ${repo}/${file_path} (intento ${attempt}/${HF_DOWNLOAD_RETRIES})"
      set +e
      HF_HUB_ENABLE_HF_TRANSFER=0 HF_XET_HIGH_PERFORMANCE=0         hf download "$repo" "$file_path" --repo-type model --local-dir "$temp_dir" "${hf_token_args[@]}" >"$cmd_log" 2>&1
      status=$?
      set -e
    fi

    if [ "$status" -eq 0 ] && [ -f "${temp_dir}/${file_path}" ]; then
      mv -f "${temp_dir}/${file_path}" "$output_path"
      rm -rf "$temp_dir"
      rmdir "$lockfile" || true
      release_slot "$slot"
      log "OK: ${output_path}"
      return 0
    fi

    if [ "$status" -eq 0 ] && [ -f "${temp_dir}/$(basename "$file_path")" ]; then
      mv -f "${temp_dir}/$(basename "$file_path")" "$output_path"
      rm -rf "$temp_dir"
      rmdir "$lockfile" || true
      release_slot "$slot"
      log "OK: ${output_path}"
      return 0
    fi

    log "AVISO: fallo descargando ${repo}/${file_path} (exit ${status}). Últimas líneas de ${cmd_log}:"
    tail -n 25 "$cmd_log" 2>/dev/null | sed -E 's/hf_[A-Za-z0-9_]+/hf_***REDACTED***/g' | while IFS= read -r line; do log "  $line"; done
    rm -rf "$temp_dir"
    attempt=$((attempt + 1))
    sleep 2
  done

  {
    echo "FAILED ${repo}/${file_path} -> ${output_path}"
    echo "  Posibles causas: token sin acceso al repo gated, términos no aceptados, ruta de archivo inexistente, rate-limit/red, o incompatibilidad hf_transfer/xet."
    echo "  Último log: ${cmd_log}"
  } >> "$HF_FAILURE_REPORT" 2>/dev/null || true

  rmdir "$lockfile" || true
  release_slot "$slot"
  return 1
}

acquire_slot() {
  local i slot
  while true; do
    i=1
    while [ "$i" -le "$HF_MAX_PARALLEL" ]; do
      slot="${HF_SEMAPHORE_DIR}/slot_${i}"
      if mkdir "$slot" 2>/dev/null; then
        echo "$slot"
        return 0
      fi
      i=$((i + 1))
    done
    sleep 0.2
  done
}

release_slot() {
  rmdir "$1" 2>/dev/null || rm -rf "$1"
}

create_symlink_or_copy() {
  local source="$1"
  local alias_path="$2"
  [ -s "$source" ] || return 0
  [ -e "$alias_path" ] && return 0
  mkdir -p "$(dirname "$alias_path")"
  ln -s "$source" "$alias_path" 2>/dev/null || cp -f "$source" "$alias_path" 2>/dev/null || true
}

create_model_aliases() {
  local klein_model="${MODELS_DIR}/diffusion_models/FLUX2/flux-2-klein-9b-fp8.safetensors"
