#!/bin/bash
set -euo pipefail

### Configuration ###
WORKSPACE_DIR="${WORKSPACE:-/workspace}"
COMFYUI_DIR="${COMFYUI_DIR:-${WORKSPACE_DIR}/ComfyUI}"
MODELS_DIR="${MODELS_DIR:-${COMFYUI_DIR}/models}"
WORKFLOW_DIR="${WORKFLOW_DIR:-${COMFYUI_DIR}/user/default/workflows}"
CUSTOM_NODES_DIR="${CUSTOM_NODES_DIR:-${COMFYUI_DIR}/custom_nodes}"
API_PAYLOAD_DIR="${API_PAYLOAD_DIR:-/opt/comfyui-api-wrapper/payloads}"
HF_SEMAPHORE_DIR="${WORKSPACE_DIR}/hf_download_sem_$$"
SCRIPT_LOG="${SCRIPT_LOG:-${WORKSPACE_DIR}/provisioning_script.log}"
HF_FAILURE_REPORT="${HF_FAILURE_REPORT:-${WORKSPACE_DIR}/hf_download_failures.txt}"

# Descargas simultáneas en paralelo. 2 es más estable con modelos grandes, Xet y hf_transfer.
HF_MAX_PARALLEL="${HF_MAX_PARALLEL:-2}"

# Hugging Face token (Mantenido intacto en modo lectura).
# Un token read-only sirve para descargar, pero la cuenta debe tener aceptados los términos
# de los repositorios gated (por ejemplo FLUX.2 klein 9B).
HF_TOKEN="${HF_TOKEN:-${HUGGING_FACE_HUB_TOKEN:-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}}"
HUGGING_FACE_HUB_TOKEN="${HUGGING_FACE_HUB_TOKEN:-$HF_TOKEN}"
HF_HOME="${HF_HOME:-${WORKSPACE_DIR}/.cache/huggingface}"
HF_HUB_ENABLE_HF_TRANSFER="${HF_HUB_ENABLE_HF_TRANSFER:-1}"
HF_XET_HIGH_PERFORMANCE="${HF_XET_HIGH_PERFORMANCE:-1}"
HF_DOWNLOAD_RETRIES="${HF_DOWNLOAD_RETRIES:-2}"
ALLOW_HF_DOWNLOAD_FAILURES="${ALLOW_HF_DOWNLOAD_FAILURES:-1}"
GIT_TERMINAL_PROMPT=0
export HF_TOKEN HUGGING_FACE_HUB_TOKEN HF_HOME HF_HUB_ENABLE_HF_TRANSFER HF_XET_HIGH_PERFORMANCE GIT_TERMINAL_PROMPT

# Configuración de descargas optimizada
UPDATE_COMFYUI="${UPDATE_COMFYUI:-1}"
INSTALL_COMFYUI_MANAGER="${INSTALL_COMFYUI_MANAGER:-1}"
INSTALL_KJ_NODES="${INSTALL_KJ_NODES:-1}"
INSTALL_NKD_KLEIN_TOOLS="${INSTALL_NKD_KLEIN_TOOLS:-1}"
INSTALL_NKD_PREVIEW_TOOLS="${INSTALL_NKD_PREVIEW_TOOLS:-1}"
INSTALL_OLLAMA_NODE="${INSTALL_OLLAMA_NODE:-1}"
INSTALL_CUSTOM_SCRIPTS="${INSTALL_CUSTOM_SCRIPTS:-1}"

# Estos extras no los requiere el workflow adjunto; quedan como opt-in.
INSTALL_GGUF_NODE="${INSTALL_GGUF_NODE:-0}"
INSTALL_EASY_USE="${INSTALL_EASY_USE:-0}"
INSTALL_ONE_NODE_FLUX_KLEIN="${INSTALL_ONE_NODE_FLUX_KLEIN:-0}"
DOWNLOAD_ONE_NODE_EXTRAS="${DOWNLOAD_ONE_NODE_EXTRAS:-0}"

DOWNLOAD_FLUX2_KLEIN_9B_FP8="${DOWNLOAD_FLUX2_KLEIN_9B_FP8:-1}"
INSTALL_NKD_KLEIN_WORKFLOW="${INSTALL_NKD_KLEIN_WORKFLOW:-1}"

# IA local para analizar imágenes y devolver prompts Klein.
INSTALL_OLLAMA="${INSTALL_OLLAMA:-1}"
PULL_OLLAMA_MODELS="${PULL_OLLAMA_MODELS:-1}"
OLLAMA_VISION_MODEL="${OLLAMA_VISION_MODEL:-qwen2.5vl:7b}"
OLLAMA_VISION_FALLBACK_MODEL="${OLLAMA_VISION_FALLBACK_MODEL:-moondream:latest}"
# Dolphin se usa como LLM de texto para reescribir/optimizar el prompt generado por el VLM.
# Intentamos primero el Dolphin basado en Qwen solicitado; si Ollama no lo encuentra, usamos Dolphin Llama 3 oficial como fallback.
OLLAMA_DOLPHIN_MODEL="${OLLAMA_DOLPHIN_MODEL:-${OLLAMA_TEXT_MODEL:-dolphin-2.9.2-qwen2:7b}}"
OLLAMA_DOLPHIN_FALLBACK_MODEL="${OLLAMA_DOLPHIN_FALLBACK_MODEL:-dolphin-llama3:8b}"
OLLAMA_EXTRA_MODELS="${OLLAMA_EXTRA_MODELS:-}"
OLLAMA_HOST="${OLLAMA_HOST:-127.0.0.1:11434}"
export OLLAMA_HOST OLLAMA_VISION_MODEL OLLAMA_VISION_FALLBACK_MODEL OLLAMA_DOLPHIN_MODEL OLLAMA_DOLPHIN_FALLBACK_MODEL OLLAMA_EXTRA_MODELS

UPGRADE_TORCH_FOR_RTX50="${UPGRADE_TORCH_FOR_RTX50:-0}"

if [ -z "${COMFYUI_MEMORY_ARGS:-}" ]; then
  COMFYUI_MEMORY_ARGS="--cache-none --fast-disk --highvram --disable-auto-launch"
fi

CLI_ARGS="${CLI_ARGS:-$COMFYUI_MEMORY_ARGS}"
PYTORCH_CUDA_ALLOC_CONF="${PYTORCH_CUDA_ALLOC_CONF:-expandable_segments:True}"
export COMFYUI_MEMORY_ARGS CLI_ARGS PYTORCH_CUDA_ALLOC_CONF

SKIP_CUSTOM_NODE_ERRORS="${SKIP_CUSTOM_NODE_ERRORS:-1}"
REQUIRED_FREE_GB="${REQUIRED_FREE_GB:-50}"
HF_STAGING_DIR="${HF_STAGING_DIR:-${WORKSPACE_DIR}/.hf_downloads}"

declare -a HF_MODELS=()
### End Configuration ###

log() {
  echo "[provision] $*"
  mkdir -p "$(dirname "$SCRIPT_LOG")" 2>/dev/null || true
  printf '[provision] %s\n' "$*" >> "$SCRIPT_LOG" 2>/dev/null || true
}

script_cleanup() {
  rm -rf "$HF_SEMAPHORE_DIR"
}

script_error() {
  local exit_code=$?
  local line_number=$1
  echo "[ERROR] El script falló en la línea ${line_number} con código de salida ${exit_code}" | tee -a "${MODEL_LOG:-/var/log/portal/comfyui.log}" || true
  echo "[ERROR] Revisa también: ${SCRIPT_LOG} y ${HF_FAILURE_REPORT}" | tee -a "${MODEL_LOG:-/var/log/portal/comfyui.log}" || true
}

trap script_cleanup EXIT
trap 'script_error $LINENO' ERR

# Motor de instalación rápido usando UV o Pip
fast_pip() {
  if command -v uv &> /dev/null; then
    uv pip install --no-cache-dir "$@"
  else
    python -m pip install --no-cache-dir "$@"
  fi
}

main() {
  activate_python_env
  ensure_layout
  : > "$HF_FAILURE_REPORT"
  if [ -n "$HF_TOKEN" ]; then
    log "HF_TOKEN disponible para descargas (valor oculto; compatible con token read-only)."
  else
    log "AVISO: HF_TOKEN vacío; los repositorios privados/gated fallarán."
  fi
  update_comfyui
  install_base_python_deps
  maybe_upgrade_torch_for_rtx50

  download_workflows
  install_custom_nodes
  
  # Instalar Ollama y modelos de visión para generar prompts desde imágenes.
  install_and_setup_ollama

  build_model_list
  check_workspace_free_space
  download_all_hf_models
  create_model_aliases
  write_ollama_prompt_helper
  write_comfyui_memory_launchers

  log "¡Provisioning completado! Workflow NKD Klein listo con nodos correctos y opción de IA local para analizar imágenes."
}

activate_python_env() {
  if [ -f /venv/main/bin/activate ]; then
    . /venv/main/bin/activate
  elif [ -f "${COMFYUI_DIR}/venv/bin/activate" ]; then
    . "${COMFYUI_DIR}/venv/bin/activate"
  fi
}

update_comfyui() {
  if [ "$UPDATE_COMFYUI" != "1" ] || [ ! -d "${COMFYUI_DIR}/.git" ]; then
    return 0
  fi

  log "Actualizando ComfyUI core..."
  set +e
  git -C "$COMFYUI_DIR" pull --ff-only
  local status=$?
  set -e

  if [ $status -ne 0 ]; then
    log "ComfyUI está en detached HEAD o no puede hacer pull limpio; usando fetch + reset seguro."
    git -C "$COMFYUI_DIR" fetch --depth 1 origin
    local remote_head
    remote_head=$(git -C "$COMFYUI_DIR" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null || true)
    if [ -n "$remote_head" ]; then
      git -C "$COMFYUI_DIR" reset --hard "$remote_head"
    else
      git -C "$COMFYUI_DIR" reset --hard FETCH_HEAD
    fi
  fi

  if [ -f "${COMFYUI_DIR}/requirements.txt" ]; then
    fast_pip -r "${COMFYUI_DIR}/requirements.txt"
  fi
}

check_workspace_free_space() {
  if [ "${REQUIRED_FREE_GB}" = "0" ]; then return 0; fi
  local free_gb
  free_gb=$(df -BG "$WORKSPACE_DIR" | awk 'NR==2 {gsub(/G/, "", $4); print $4}')
  free_gb="${free_gb:-0}"
  if [ "$free_gb" -lt "$REQUIRED_FREE_GB" ]; then
    log "ERROR: espacio libre insuficiente en ${WORKSPACE_DIR}: ${free_gb}GB disponibles, ${REQUIRED_FREE_GB}GB requeridos."
    return 1
  fi
  log "Espacio libre OK en ${WORKSPACE_DIR}: ${free_gb}GB disponibles."
}

maybe_upgrade_torch_for_rtx50() {
  if [ "$UPGRADE_TORCH_FOR_RTX50" != "1" ]; then return 0; fi
  log "Actualizando PyTorch..."
  fast_pip --upgrade --index-url https://download.pytorch.org/whl/cu128 torch torchvision torchaudio
}

ensure_layout() {
  mkdir -p "$WORKSPACE_DIR" "$COMFYUI_DIR" "$CUSTOM_NODES_DIR" "$WORKFLOW_DIR" \
    "$MODELS_DIR/diffusion_models" "$MODELS_DIR/text_encoders" \
    "$MODELS_DIR/vae" "$MODELS_DIR/loras" "$MODELS_DIR/background_removal" \
    "$MODELS_DIR/diffusion_models/FLUX2" "$WORKSPACE_DIR/prompt_helpers" \
    "$HF_SEMAPHORE_DIR" "$HF_HOME" "$HF_STAGING_DIR"
}

install_base_python_deps() {
  log "Instalando dependencias críticas de Python..."
  if command -v uv &> /dev/null; then
    uv pip install --no-cache-dir --upgrade pip setuptools wheel
  else
    python -m pip install --no-cache-dir --upgrade pip setuptools wheel
  fi
  
  fast_pip --upgrade \
    huggingface_hub hf_transfer hf-xet gguf safetensors \
    accelerate transformers sentencepiece protobuf qwen-vl-utils rotary-embedding-torch
}

run_maybe_nonfatal() {
  local description="$1"
  shift
  if "$@"; then return 0; fi
  local status=$?
  log "AVISO: fallo en ${description} (exit ${status})."
  if [ "$SKIP_CUSTOM_NODE_ERRORS" = "1" ]; then
    log "Continuando porque SKIP_CUSTOM_NODE_ERRORS=1."
    return 0
  fi
  return "$status"
}

clone_or_update() {
  local repo_url="$1"
  local dir_name="$2"
  local target_dir="${CUSTOM_NODES_DIR}/${dir_name}"

  if ! git ls-remote --exit-code "$repo_url" HEAD >/dev/null 2>&1; then
    log "AVISO: repo no accesible sin credenciales, se omite ${dir_name}: ${repo_url}"
    return 1
  fi

  if [ -e "$target_dir" ] && [ ! -d "${target_dir}/.git" ]; then
    log "AVISO: ${target_dir} existe pero no es un repo git; se mueve a custom_nodes_disabled."
    mkdir -p "${COMFYUI_DIR}/custom_nodes_disabled"
    mv "$target_dir" "${COMFYUI_DIR}/custom_nodes_disabled/${dir_name}_nongit_$(date +%Y%m%d_%H%M%S)"
  fi

  if [ -d "${target_dir}/.git" ]; then
    git -C "$target_dir" fetch --depth 1 origin
    local remote_head
    remote_head=$(git -C "$target_dir" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null || true)
    if [ -n "$remote_head" ]; then
      git -C "$target_dir" reset --hard "$remote_head"
    else
      git -C "$target_dir" reset --hard FETCH_HEAD
    fi
  else
    git clone --depth 1 "$repo_url" "$target_dir"
  fi
}

clone_or_update_safe() {
  run_maybe_nonfatal "clone/update $2" clone_or_update "$1" "$2"
}

install_node_requirements() {
  if [ -f "${1}/requirements.txt" ]; then
    fast_pip -r "${1}/requirements.txt"
  fi
}

run_node_install_script() {
  if [ -f "${1}/install.py" ]; then
    python "${1}/install.py"
  elif [ -f "${1}/install.sh" ]; then
    bash "${1}/install.sh"
  fi
}

disable_custom_node_if_present() {
  local src_dir="${CUSTOM_NODES_DIR}/${1}"
  if [ -d "$src_dir" ]; then
    mkdir -p "${COMFYUI_DIR}/custom_nodes_disabled"
    mv "$src_dir" "${COMFYUI_DIR}/custom_nodes_disabled/${1}_$(date +%Y%m%d_%H%M%S)"
  fi
}

dedupe_comfyui_manager() {
  if [ -d "${CUSTOM_NODES_DIR}/ComfyUI-Manager" ] && [ -d "${CUSTOM_NODES_DIR}/comfyui-manager" ]; then
    disable_custom_node_if_present "comfyui-manager"
  fi
}

install_custom_nodes() {
  log "Clonando nodos personalizados requeridos por el workflow NKD Klein..."
  dedupe_comfyui_manager

  # Evitar repos antiguos o erróneos que pueden duplicar nodos o pedir credenciales.
  if [ -d "${CUSTOM_NODES_DIR}/ComfyUI-Ollama" ] && [ ! -d "${CUSTOM_NODES_DIR}/comfyui-ollama/.git" ]; then
    disable_custom_node_if_present "ComfyUI-Ollama"
  fi
  if [ -d "${CUSTOM_NODES_DIR}/comfyui-nkd-popup-preview" ] && [ ! -d "${CUSTOM_NODES_DIR}/ComfyUI-NKD-Preview-Tools/.git" ]; then
    disable_custom_node_if_present "comfyui-nkd-popup-preview"
  fi

  if [ "$INSTALL_COMFYUI_MANAGER" = "1" ]; then
    clone_or_update_safe "https://github.com/Comfy-Org/ComfyUI-Manager.git" "ComfyUI-Manager"
    dedupe_comfyui_manager
  fi

  if [ "$INSTALL_KJ_NODES" = "1" ]; then
    clone_or_update_safe "https://github.com/kijai/ComfyUI-KJNodes.git" "ComfyUI-KJNodes"
  fi
  if [ "$INSTALL_NKD_KLEIN_TOOLS" = "1" ]; then
    clone_or_update_safe "https://github.com/Nekodificador/ComfyUI-NKD-Klein-Tools.git" "ComfyUI-NKD-Klein-Tools"
  fi
  if [ "$INSTALL_NKD_PREVIEW_TOOLS" = "1" ]; then
    clone_or_update_safe "https://github.com/Nekodificador/ComfyUI-NKD-Preview-Tools.git" "ComfyUI-NKD-Preview-Tools"
  fi
  if [ "$INSTALL_OLLAMA_NODE" = "1" ]; then
    clone_or_update_safe "https://github.com/stavsap/comfyui-ollama.git" "comfyui-ollama"
  fi
  if [ "$INSTALL_CUSTOM_SCRIPTS" = "1" ]; then
    clone_or_update_safe "https://github.com/pythongosssss/ComfyUI-Custom-Scripts.git" "ComfyUI-Custom-Scripts"
  fi

  # Extras opcionales. No son necesarios para el workflow adjunto.
  if [ "$INSTALL_GGUF_NODE" = "1" ]; then
    clone_or_update_safe "https://github.com/city96/ComfyUI-GGUF.git" "ComfyUI-GGUF"
  fi
  if [ "$INSTALL_EASY_USE" = "1" ]; then
    clone_or_update_safe "https://github.com/yolain/ComfyUI-Easy-Use.git" "ComfyUI-Easy-Use"
  fi
  if [ "$INSTALL_ONE_NODE_FLUX_KLEIN" = "1" ]; then
    clone_or_update_safe "https://github.com/yanokusnir-ai/one-node-flux-2-klein.git" "one-node-flux-2-klein"
  fi

  local node_dirs=(
    "${CUSTOM_NODES_DIR}/ComfyUI-Manager"
    "${CUSTOM_NODES_DIR}/ComfyUI-KJNodes"
    "${CUSTOM_NODES_DIR}/ComfyUI-NKD-Klein-Tools"
    "${CUSTOM_NODES_DIR}/ComfyUI-NKD-Preview-Tools"
    "${CUSTOM_NODES_DIR}/comfyui-ollama"
    "${CUSTOM_NODES_DIR}/ComfyUI-Custom-Scripts"
    "${CUSTOM_NODES_DIR}/ComfyUI-GGUF"
    "${CUSTOM_NODES_DIR}/ComfyUI-Easy-Use"
    "${CUSTOM_NODES_DIR}/one-node-flux-2-klein"
  )

  log "Instalando librerías de los nodos presentes..."
  for nd in "${node_dirs[@]}"; do
    [ -d "$nd" ] || continue
    run_maybe_nonfatal "reqs $nd" install_node_requirements "$nd"
    run_maybe_nonfatal "script $nd" run_node_install_script "$nd"
  done
}

pull_ollama_model() {
  local model="$1"
  local description="${2:-modelo Ollama}"
  if [ -z "$model" ]; then
    return 1
  fi
  log "Descargando ${description}: ${model}"
  if ollama pull "$model" >>"${WORKSPACE_DIR}/ollama.log" 2>&1; then
    return 0
  fi
  log "AVISO: no se pudo descargar ${model}. Revisa ${WORKSPACE_DIR}/ollama.log."
  return 1
}

remember_prompt_refiner_model() {
  local model="$1"
  if [ -n "$model" ]; then
    printf '%s
' "$model" > "${WORKSPACE_DIR}/.ollama_prompt_refiner_model"
  fi
}

install_and_setup_ollama() {
  if [ "$INSTALL_OLLAMA" != "1" ]; then
    log "Ollama desactivado por INSTALL_OLLAMA=0."
    return 0
  fi

  log "Instalando Ollama local de forma silenciosa..."
  curl -fsSL https://ollama.com/install.sh | sh >/dev/null 2>&1 || true

  if ! command -v ollama >/dev/null 2>&1; then
    log "AVISO: ollama no está disponible tras la instalación; se omiten modelos IA locales."
    return 0
  fi

  log "Iniciando servicio de Ollama en segundo plano..."
  if ! curl -s "http://${OLLAMA_HOST}/api/tags" >/dev/null 2>&1; then
    ollama serve > "${WORKSPACE_DIR}/ollama.log" 2>&1 &
  fi

  log "Esperando a que Ollama responda en ${OLLAMA_HOST}..."
  local timeout=60
  while ! curl -s "http://${OLLAMA_HOST}/api/tags" >/dev/null 2>&1 && [ "$timeout" -gt 0 ]; do
    sleep 1
    timeout=$((timeout - 1))
  done

  if ! curl -s "http://${OLLAMA_HOST}/api/tags" >/dev/null 2>&1; then
    log "AVISO: Ollama no respondió; ComfyUI arrancará igualmente. Revisa ${WORKSPACE_DIR}/ollama.log."
    return 0
  fi

  if [ "$PULL_OLLAMA_MODELS" != "1" ]; then
    log "PULL_OLLAMA_MODELS=0; no se descargan modelos Ollama."
    return 0
  fi

  pull_ollama_model "$OLLAMA_VISION_MODEL" "modelo de visión principal para analizar imágenes" || true
  pull_ollama_model "$OLLAMA_VISION_FALLBACK_MODEL" "modelo de visión ligero de reserva" || true

  if pull_ollama_model "$OLLAMA_DOLPHIN_MODEL" "modelo Dolphin para reescritura de prompts"; then
    remember_prompt_refiner_model "$OLLAMA_DOLPHIN_MODEL"
  elif pull_ollama_model "$OLLAMA_DOLPHIN_FALLBACK_MODEL" "modelo Dolphin fallback para reescritura de prompts"; then
    remember_prompt_refiner_model "$OLLAMA_DOLPHIN_FALLBACK_MODEL"
  else
    log "AVISO: no hay modelo Dolphin disponible; se mantiene solo el análisis visual."
  fi

  if [ -n "$OLLAMA_EXTRA_MODELS" ]; then
    local extra_model
    for extra_model in $OLLAMA_EXTRA_MODELS; do
      pull_ollama_model "$extra_model" "modelo Ollama extra" || true
    done
  fi
}

